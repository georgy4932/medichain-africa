{
  "headers": [
    {
      "source": "/orela-landing.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/ng/:path*", "destination": "/ng/index.html" },
    { "source": "/ng", "destination": "/ng/index.html" },
    { "source": "/", "destination": "/orela-landing.html" }
  ]
}
